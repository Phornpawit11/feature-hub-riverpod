NODE_ENV=development
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>
PORT=3000
JWT_ACCESS_SECRET=your_local_dev_access_secret
JWT_REFRESH_SECRET=your_local_dev_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# Temporary migration alias if your environment still uses the legacy key:
# JWT_SECRET=your_legacy_jwt_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
